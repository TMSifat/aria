# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (Docker)
DATABASE_URL="postgresql://aria:password@localhost:5432/aria_db"
# Direct URL used for migrations. For local dev this is the same as DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://aria:password@localhost:5432/aria_db"
# For Neon (prod) — use pooled URL for app, direct for migrations
# DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/aria_db?sslmode=require&pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/aria_db?sslmode=require"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Upstash (prod):
# REDIS_URL="rediss://:password@xxx.upstash.io:port"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-change-me-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# Create at: https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── AI provider ─────────────────────────────────────────────────────────────
# Chat uses Gemini when GOOGLE_API_KEY is set, otherwise Claude.
# Force a provider with AI_PROVIDER=google | anthropic.
# Get a free Gemini key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=""
GOOGLE_MODEL="gemini-2.5-flash"

# Anthropic (optional if using Google)
ANTHROPIC_API_KEY="sk-ant-api03-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret — get from: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs — create in Stripe dashboard > Products
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_AGENCY_PRICE_ID="price_..."

# ─── Email (password reset) ──────────────────────────────────────────────────
# Get a key at https://resend.com — without it, dev logs emails to the console.
RESEND_API_KEY=""
EMAIL_FROM="Aria <onboarding@resend.dev>"

# ─── NestJS API ──────────────────────────────────────────────────────────────
# Used by Next.js to call NestJS internally (for usage logging from /api/chat)
NEST_API_URL="http://localhost:3001"
NEST_API_INTERNAL_SECRET="generate-a-random-secret-for-internal-calls"
WEB_URL="http://localhost:3000"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
